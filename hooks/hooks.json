{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/snap_transcript.py snap 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Snapshotting history to PNG"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "sleep 4; python3 ${CLAUDE_PLUGIN_ROOT}/snap_transcript.py announce 2>/dev/null || true",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
